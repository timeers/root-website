{% extends 'the_keep/base.html' %}
{% load i18n static %}
{% block title %}Grouping - {{ survey.title }} | {% endblock %}

{% block content %}
<div class="content-section">
    {% include 'the_tavern/partials/survey_navigation.html' %}

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="root-title mb-2">{% trans 'Player Grouping' %}</h1>
            <p class="text-muted mb-0">{{ survey.title }}</p>
        </div>
        {% if session and not is_processing %}
        <div class="d-flex gap-2">
            {% if not is_finalized %}
            <button class="btn btn-success" onclick="finalizeSession()">
                <i class="bi bi-check-lg"></i> {% trans 'Finalize' %}
            </button>
            {% endif %}
            {% if is_finalized %}
            <span class="badge bg-success fs-6"><i class="bi bi-check-circle"></i> {% trans 'Finalized' %}</span>
            {% endif %}
        </div>
        {% endif %}
    </div>

    <!-- Survey Stats -->
    <div class="row g-3 mb-4">
        <div class="{% if waitlist_count %}col-md-3{% else %}col-md-4{% endif %}">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-people fs-2 text-primary"></i>
                    <h3 class="mb-0 mt-2">{{ total_responses }}</h3>
                    <small class="text-muted">{% trans 'Total Response' %}{{ total_responses|pluralize }}</small>
                </div>
            </div>
        </div>
        {% if waitlist_count %}
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-hourglass fs-2 text-warning"></i>
                    <h3 class="mb-0 mt-2">{{ waitlist_count }}</h3>
                    <small class="text-muted">{% trans 'On Waitlist' %}</small>
                </div>
            </div>
        </div>
        {% endif %}
        <div class="{% if waitlist_count %}col-md-3{% else %}col-md-4{% endif %}">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-question-circle fs-2 text-success"></i>
                    <h3 class="mb-0 mt-2">{{ ungrouped_count }}</h3>
                    <small class="text-muted">{% trans 'Ungrouped' %}</small>
                </div>
            </div>
        </div>
        
        <div class="{% if waitlist_count %}col-md-3{% else %}col-md-4{% endif %}">
            <div class="card h-100 border-info">
                <div class="card-body text-center">
                    <i class="bi bi-diagram-3 fs-2 text-info"></i>
                    <h3 class="mb-0 mt-2">{{ group_count }}</h3>
                    <small class="text-muted">{% trans 'Group' %}{{ group_count|pluralize }}</small>
                </div>
            </div>
        </div>
        
    </div>

    <!-- Configuration Form -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-gear"></i> {% trans 'Grouping Settings' %}</h5>
            {% if session and not is_finalized and not is_processing %}
            <form method="post" style="display: inline;">
                {% csrf_token %}
                <input type="hidden" name="action" value="reset_session">
                <button type="submit" class="btn btn-sm btn-outline-danger"
                        onclick="return confirm('This will delete all groups and reset. Are you sure?')">
                    <i class="bi bi-arrow-counterclockwise"></i> {% trans 'Reset' %}
                </button>
            </form>
            {% endif %}
        </div>
        <div class="card-body">
            {% if is_finalized %}
            <div class="alert alert-success mb-0">
                <i class="bi bi-lock-fill"></i>
                <strong>{% trans 'Grouping Finalized' %}</strong>
                <p class="mb-0">Groups have been finalized and can no longer be modified. To make changes, reset the session using the button above.</p>
            </div>
            {% elif is_processing %}
            <!-- Processing State -->
            <div class="alert alert-info mb-0">
                <i class="bi bi-hourglass-split"></i>
                <strong>{% trans 'Processing...' %}</strong>
                <p class="mb-0">Groups are being generated. Please wait.</p>
            </div>

            {% else %}
            <form method="post">
                {% csrf_token %}
                <input type="hidden" name="action" value="generate">

                {% if not has_availability %}
                <!-- No availability questions - show grouping type selector -->
                <div class="mb-4">
                    <label class="form-label fw-bold">{% trans 'Grouping Method' %}</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="grouping_type" id="type_random" value="random"
                               {% if not session or session.grouping_type == 'random' %}checked{% endif %}>
                        <label class="form-check-label" for="type_random">
                            <strong>{% trans 'Random Assignment' %}</strong>
                            <br><small class="text-muted">Randomly distribute players into groups</small>
                        </label>
                    </div>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="radio" name="grouping_type" id="type_manual" value="manual"
                               {% if session and session.grouping_type == 'manual' %}checked{% endif %}>
                        <label class="form-check-label" for="type_manual">
                            <strong>{% trans 'Manual Assignment' %}</strong>
                            <br><small class="text-muted">Manually drag players into groups</small>
                        </label>
                    </div>
                </div>
                {% else %}
                <input type="hidden" name="grouping_type" value="availability">

                <!-- Algorithm Selection for availability-based grouping -->
                <div class="mb-4">
                    <label class="form-label fw-bold">{% trans 'Algorithm' %}</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="algorithm" id="algo_greedy" value="greedy"
                               {% if not session or session.algorithm == 'greedy' %}checked{% endif %}>
                        <label class="form-check-label" for="algo_greedy">
                            <strong>{% trans 'Optimized' %}</strong>
                            <br><small class="text-muted">Prioritizes best availability matches, may leave some players ungrouped</small>
                        </label>
                    </div>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="radio" name="algorithm" id="algo_random" value="random"
                               {% if session and session.algorithm == 'random' %}checked{% endif %}>
                        <label class="form-check-label" for="algo_random">
                            <strong>{% trans 'Random' %}</strong>
                            <br><small class="text-muted">Randomly assigns players to groups evenly</small>
                        </label>
                    </div>
                </div>
                {% endif %}

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label for="min_group_size" class="form-label">{% trans 'Minimum Group Size' %}</label>
                        <input type="number" class="form-control" id="min_group_size" name="min_group_size"
                               value="{{ session.min_group_size|default:4 }}" min="2" max="12">
                        <small class="text-muted">Minimum players per group</small>
                    </div>
                    <div class="col-md-6">
                        <label for="max_group_size" class="form-label">{% trans 'Maximum Group Size' %}</label>
                        <input type="number" class="form-control" id="max_group_size" name="max_group_size"
                               value="{{ session.max_group_size|default:4 }}" min="2" max="12">
                        <small class="text-muted">Maximum players per group</small>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label for="naming_convention" class="form-label">{% trans 'Group Naming' %}</label>
                        <select class="form-select" id="naming_convention" name="naming_convention">
                            {% for value, label in naming_conventions %}
                            <option value="{{ value }}" {% if session.naming_convention == value %}selected{% endif %}>
                                {{ label }}
                            </option>
                            {% endfor %}
                        </select>
                        <small class="text-muted">How groups will be named (e.g., Group 1, Alpha, I)</small>
                    </div>
                </div>

                {% if survey.has_waitlist and waitlist_count > 0 %}
                <div class="card bg-light mb-4">
                    <div class="card-body">
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="include_waitlist" name="include_waitlist"
                                   {% if session and session.include_waitlist %}checked{% endif %}
                                   onchange="toggleWaitlistCount()">
                            <label class="form-check-label" for="include_waitlist">
                                <strong>{% trans 'Include Waitlist Players' %}</strong>
                            </label>
                        </div>
                        <div id="waitlist_count_wrapper" style="{% if not session or not session.include_waitlist %}display: none;{% endif %}">
                            <label for="waitlist_count" class="form-label">{% trans 'Number of waitlist players to include' %}</label>
                            <input type="number" class="form-control" id="waitlist_count" name="waitlist_count"
                                   value="{% if included_waitlist_count > 0 %}{{ included_waitlist_count }}{% else %}{{ waitlist_count }}{% endif %}"
                                   min="1" max="{{ waitlist_count }}">
                            <small class="text-muted">{{ waitlist_count }} player{{ waitlist_count|pluralize }} on waitlist</small>
                        </div>
                    </div>
                </div>
                {% endif %}

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-play-fill"></i>
                        {% if session %}{% trans 'Regenerate Groups' %}{% else %}{% trans 'Generate Groups' %}{% endif %}
                    </button>
                    <a href="{{ return_to }}" class="btn btn-outline-secondary">{% trans 'Cancel' %}</a>
                </div>
            </form>
            {% endif %}
        </div>
    </div>

    {% if is_processing %}
    <!-- Processing Status -->
    <div id="processing-container"
        hx-get="{% url 'grouping-status' survey.slug session.id %}"
        hx-trigger="every 2s"
        hx-swap="innerHTML">
        {% include 'the_tavern/partials/grouping_processing.html' %}
    </div>
    {% elif has_error %}
    <div class="alert alert-danger mb-4">
        <h5><i class="bi bi-exclamation-triangle"></i> {% trans 'Error' %}</h5>
        <p>{{ session.notes }}</p>
    </div>
    {% endif %}

    {% if session and not is_processing %}
    <!-- Groups Section -->
    {% if groups %}
    <!-- Groups Grid -->
    <div class="row g-3 mb-4" id="groups-container">
        {% for group in groups %}
        <div class="col-md-4 col-lg-3" data-group-id="{{ group.id }}">
            <div class="card h-100 group-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>{% if group.name %}{{ group.name }}{% else %}Group {{ group.group_number }}{% endif %}</strong>
                    <span class="badge bg-secondary">{{ group.member_count }}</span>
                </div>
                <div class="card-body p-2">
                    <!-- Group Stats -->
                    {% if session.grouping_type == 'availability' %}
                    <div class="small text-muted mb-2">
                        <i class="bi bi-clock"></i> {{ group.total_overlap_hours }}h overlap
                        {% if group.best_consecutive_block %}
                        ({{ group.best_consecutive_block }}h consecutive)
                        {% endif %}
                    </div>
                    {% endif %}
                    <!-- Members List -->
                    <ul class="list-group list-group-flush group-members {% if not is_finalized %}sortable-group{% endif %}" data-group-id="{{ group.id }}">
                        {% for sp in group.session_players.all %}
                        {% if sp.status == 'grouped' %}
                        <li class="list-group-item d-flex align-items-center player-item" data-player-id="{{ sp.id }}" data-source="group">
                            {% if not is_finalized %}<i class="bi bi-grip-vertical drag-handle me-2 text-muted"></i>{% endif %}
                            {% if sp.profile.image %}
                            <img src="{{ sp.profile.image.url }}" alt="" class="rounded-circle me-2" style="width: 24px; height: 24px;">
                            {% else %}
                            <i class="bi bi-person-circle me-2"></i>
                            {% endif %}
                            <span class="flex-grow-1">{{ sp.profile.display_name }}</span>
                            {% if sp.added_via == 'manual' %}
                            <small class="text-muted"><i class="bi bi-hand-index"></i></small>
                            {% elif sp.added_via == 'reassigned' %}
                            <small class="text-muted"><i class="bi bi-arrow-left-right"></i></small>
                            {% endif %}
                        </li>
                        {% endif %}
                        {% empty %}
                        <li class="list-group-item text-muted text-center empty-placeholder">
                            <small>{% trans 'Drop players here' %}</small>
                        </li>
                        {% endfor %}
                    </ul>
                </div>
                {% if not is_finalized and group.member_count == 0 %}
                <div class="card-footer">
                    <button class="btn btn-sm btn-outline-danger w-100" onclick="deleteGroup({{ group.id }})">
                        <i class="bi bi-trash"></i> {% trans 'Delete' %}
                    </button>
                </div>
                {% endif %}
            </div>
        </div>
        {% endfor %}

        <!-- New Group Dropzone -->
        {% if not is_finalized %}
        <div class="col-md-4 col-lg-3">
            <div class="card h-100 border-dashed" style="border-style: dashed !important;">
                <div class="card-body d-flex flex-column justify-content-center align-items-center text-muted" id="new-group-zone">
                    <i class="bi bi-plus-circle fs-1 mb-2"></i>
                    <p class="mb-0">{% trans 'Drop to create new group' %}</p>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
    {% endif %}

    <!-- Ungrouped Players -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-person-x"></i> {% trans 'Ungrouped Players' %} ({{ ungrouped_count }})</h5>
        </div>
        <div class="card-body">
            {% if ungrouped_players %}
            <ul class="list-group list-group-flush {% if not is_finalized %}sortable-ungrouped{% endif %}" id="ungrouped-players" data-group-id="ungrouped">
                {% for sp in ungrouped_players %}
                <li class="list-group-item d-flex align-items-center player-item ungrouped-item" data-player-id="{{ sp.id }}" data-source="ungrouped">
                    {% if not is_finalized %}<i class="bi bi-grip-vertical drag-handle me-2 text-muted"></i>{% endif %}
                    {% if sp.profile.image %}
                    <img src="{{ sp.profile.image.url }}" alt="" class="rounded-circle me-2" style="width: 24px; height: 24px;">
                    {% else %}
                    <i class="bi bi-person-circle me-2"></i>
                    {% endif %}
                    <span class="flex-grow-1">{{ sp.profile.display_name }}</span>
                    {% if sp.best_fit_group %}
                    <small class="text-muted me-2" title="Best fit: Group {{ sp.best_fit_group.group_number }} ({{ sp.best_fit_overlap_hours }}h overlap)">
                        <i class="bi bi-arrow-right"></i> G{{ sp.best_fit_group.group_number }}
                    </small>
                    {% endif %}
                    {% if session.grouping_type == 'availability' and sp.availability_hours %}
                    <small class="text-muted">{{ sp.availability_hours|length }}h</small>
                    {% endif %}
                </li>
                {% endfor %}
            </ul>
            {% else %}
            <p class="text-muted mb-0">No ungrouped players.</p>
            {% endif %}
        </div>
    </div>

    <!-- Survey Waitlist (responses not in session) -->
    {% if survey.has_waitlist and survey_waitlist_responses %}
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="bi bi-clock-history"></i> {% trans 'Survey Waitlist' %} ({{ survey_waitlist_count }})</h5>
        </div>
        <div class="card-body">
            <p class="text-muted small mb-3">Survey respondents still on the waitlist (not yet added to this grouping session). Drag to add them to the session.</p>

            <ul class="list-group list-group-flush {% if not is_finalized %}sortable-survey-waitlist{% endif %}" id="survey-waitlist-responses" data-group-id="survey-waitlist">
                {% for response in survey_waitlist_responses %}
                <li class="list-group-item d-flex align-items-center player-item survey-waitlist-item" data-response-id="{{ response.id }}" data-source="survey-waitlist">
                    {% if not is_finalized %}<i class="bi bi-grip-vertical drag-handle me-2 text-muted"></i>{% endif %}
                    {% if response.profile.image %}
                    <img src="{{ response.profile.image.url }}" alt="" class="rounded-circle me-2" style="width: 24px; height: 24px;">
                    {% else %}
                    <i class="bi bi-person-circle me-2"></i>
                    {% endif %}
                    <span class="flex-grow-1">{{ response.profile.display_name }}</span>
                    <span class="badge bg-secondary">#{{ response.response_position }}</span>
                </li>
                {% endfor %}
            </ul>
        </div>
    </div>
    {% endif %}
    {% endif %}
</div>

<!-- Finalize Confirmation Modal -->
<div class="modal fade" id="finalizeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{% trans 'Finalize Groups' %}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Once finalized, groups cannot be modified.</p>
                {% if ungrouped_count > 0 %}
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i>
                    There are still {{ ungrouped_count }} ungrouped player{{ ungrouped_count|pluralize }}.
                </div>
                {% endif %}
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{% trans 'Cancel' %}</button>
                <button type="button" class="btn btn-success" onclick="confirmFinalize()">{% trans 'Finalize' %}</button>
            </div>
        </div>
    </div>
</div>

<style>
.group-card {
    transition: box-shadow 0.2s;
}
.group-card:hover {
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
}
.player-item {
    cursor: grab;
    transition: background-color 0.2s;
}
.player-item:hover {
    background-color: rgba(0, 123, 255, 0.1);
}
.sortable-ghost {
    opacity: 0.4;
    background-color: #c8ebfb;
}
.sortable-drag {
    opacity: 0.9;
}
.drag-handle {
    cursor: grab;
}
.border-dashed {
    border: 2px dashed #dee2e6 !important;
}
.empty-placeholder {
    min-height: 50px;
}
.survey-waitlist-item {
    background-color: rgba(108, 117, 125, 0.05);
}
.survey-waitlist-item:hover {
    background-color: rgba(108, 117, 125, 0.15);
}
</style>

<script>
function toggleWaitlistCount() {
    const checkbox = document.getElementById('include_waitlist');
    const wrapper = document.getElementById('waitlist_count_wrapper');
    if (checkbox && wrapper) {
        wrapper.style.display = checkbox.checked ? 'block' : 'none';
    }
}
</script>

{% if session and not is_processing and not is_finalized %}
<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
<script>
const csrfToken = '{{ csrf_token }}';
const surveySlug = '{{ survey.slug }}';
const sessionId = {{ session.id }};

// Initialize Sortable for each group
document.querySelectorAll('.sortable-group').forEach(container => {
    new Sortable(container, {
        group: 'players',
        animation: 150,
        handle: '.drag-handle',
        ghostClass: 'sortable-ghost',
        dragClass: 'sortable-drag',
        onAdd: function(evt) {
            const playerId = evt.item.dataset.playerId;
            const responseId = evt.item.dataset.responseId;
            const toGroupId = evt.to.dataset.groupId;
            const source = evt.item.dataset.source;

            // Hide empty placeholder if it exists
            const placeholder = evt.to.querySelector('.empty-placeholder');
            if (placeholder) placeholder.style.display = 'none';

            if (source === 'survey-waitlist') {
                // Adding from survey waitlist (new to session)
                addSurveyResponseToSession(responseId, toGroupId);
            } else if (source === 'session-waitlist') {
                // Moving from session waitlist to group
                moveFromWaitlist(playerId, toGroupId);
            } else if (source === 'ungrouped') {
                // Adding from ungrouped
                addToGroup(playerId, toGroupId);
            } else {
                // Moving between groups
                const fromGroupId = evt.from.dataset.groupId;
                movePlayer(playerId, fromGroupId, toGroupId);
            }
        },
        onRemove: function(evt) {
            // Show empty placeholder if group is now empty
            const remaining = Array.from(evt.from.children).filter(
                el => !el.classList.contains('empty-placeholder')
            );
            if (remaining.length === 0) {
                let placeholder = evt.from.querySelector('.empty-placeholder');
                if (!placeholder) {
                    placeholder = document.createElement('li');
                    placeholder.className = 'list-group-item text-muted text-center empty-placeholder';
                    placeholder.innerHTML = '<small>Drop players here</small>';
                    evt.from.appendChild(placeholder);
                }
                placeholder.style.display = '';
            }
        }
    });
});

// Initialize Sortable for ungrouped
const ungroupedContainer = document.getElementById('ungrouped-players');
if (ungroupedContainer) {
    new Sortable(ungroupedContainer, {
        group: 'players',
        animation: 150,
        handle: '.drag-handle',
        ghostClass: 'sortable-ghost',
        onAdd: function(evt) {
            const playerId = evt.item.dataset.playerId;
            const responseId = evt.item.dataset.responseId;
            const source = evt.item.dataset.source;

            if (source === 'survey-waitlist') {
                // Adding from survey waitlist to ungrouped
                addSurveyResponseToSession(responseId, null);
            } else if (source === 'session-waitlist') {
                // Moving from session waitlist to ungrouped
                moveFromWaitlist(playerId, null);
            } else if (source === 'group') {
                // Removing from group to ungrouped
                removeFromGroup(playerId);
            }
        }
    });
}

// Initialize Sortable for survey waitlist (read-only, items can only be dragged out)
const surveyWaitlistContainer = document.getElementById('survey-waitlist-responses');
if (surveyWaitlistContainer) {
    new Sortable(surveyWaitlistContainer, {
        group: {
            name: 'players',
            pull: true,
            put: false  // Cannot drop items into survey waitlist
        },
        animation: 150,
        handle: '.drag-handle',
        ghostClass: 'sortable-ghost',
    });
}

// Initialize Sortable for new group zone
const newGroupZone = document.getElementById('new-group-zone');
if (newGroupZone) {
    new Sortable(newGroupZone, {
        group: 'players',
        animation: 150,
        onAdd: function(evt) {
            const playerId = evt.item.dataset.playerId;
            const responseId = evt.item.dataset.responseId;
            const source = evt.item.dataset.source;
            createNewGroup(playerId, responseId, source);
            // Remove the item - it will be re-rendered when page refreshes
            evt.item.remove();
        }
    });
}

function movePlayer(playerId, fromGroupId, toGroupId) {
    fetch(`/surveys/${surveySlug}/grouping/${sessionId}/move-player/`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': csrfToken
        },
        body: JSON.stringify({
            player_id: playerId,
            from_group_id: fromGroupId,
            to_group_id: toGroupId
        })
    })
    .then(response => response.json())
    .then(data => {
        if (!data.success) {
            alert('Error: ' + data.error);
            location.reload();
        }
    })
    .catch(error => {
        console.error('Error:', error);
        location.reload();
    });
}

function addToGroup(playerId, groupId) {
    fetch(`/surveys/${surveySlug}/grouping/${sessionId}/add-to-group/`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': csrfToken
        },
        body: JSON.stringify({
            player_id: playerId,
            group_id: groupId
        })
    })
    .then(response => response.json())
    .then(data => {
        if (!data.success) {
            alert('Error: ' + data.error);
            location.reload();
        }
    })
    .catch(error => {
        console.error('Error:', error);
        location.reload();
    });
}

function removeFromGroup(playerId) {
    fetch(`/surveys/${surveySlug}/grouping/${sessionId}/remove-from-group/`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': csrfToken
        },
        body: JSON.stringify({
            player_id: playerId
        })
    })
    .then(response => response.json())
    .then(data => {
        if (!data.success) {
            alert('Error: ' + data.error);
            location.reload();
        }
    })
    .catch(error => {
        console.error('Error:', error);
        location.reload();
    });
}

function moveFromWaitlist(playerId, groupId) {
    fetch(`/surveys/${surveySlug}/grouping/${sessionId}/move-from-waitlist/`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': csrfToken
        },
        body: JSON.stringify({
            player_id: playerId,
            group_id: groupId
        })
    })
    .then(response => response.json())
    .then(data => {
        if (!data.success) {
            alert('Error: ' + data.error);
            location.reload();
        }
    })
    .catch(error => {
        console.error('Error:', error);
        location.reload();
    });
}

function addSurveyResponseToSession(responseId, groupId) {
    fetch(`/surveys/${surveySlug}/grouping/${sessionId}/add-survey-response/`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': csrfToken
        },
        body: JSON.stringify({
            response_id: responseId,
            group_id: groupId
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Error: ' + data.error);
            location.reload();
        }
    })
    .catch(error => {
        console.error('Error:', error);
        location.reload();
    });
}

function createNewGroup(playerId, responseId, source) {
    const body = {};

    if (source === 'survey-waitlist') {
        // First add to session, then page will reload
        addSurveyResponseToSession(responseId, null);
        return;
    }

    if (playerId) {
        body.player_id = playerId;
    }

    fetch(`/surveys/${surveySlug}/grouping/${sessionId}/create-group/`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': csrfToken
        },
        body: JSON.stringify(body)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Error: ' + data.error);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        location.reload();
    });
}

function deleteGroup(groupId) {
    if (!confirm('Delete this empty group?')) return;

    fetch(`/surveys/${surveySlug}/grouping/${sessionId}/delete-group/`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': csrfToken
        },
        body: JSON.stringify({
            group_id: groupId
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Error: ' + data.error);
        }
    })
    .catch(error => {
        console.error('Error:', error);
    });
}

function finalizeSession() {
    const modal = new bootstrap.Modal(document.getElementById('finalizeModal'));
    modal.show();
}

function confirmFinalize() {
    fetch(`/surveys/${surveySlug}/grouping/${sessionId}/finalize/`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': csrfToken
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Error: ' + data.error);
        }
    })
    .catch(error => {
        console.error('Error:', error);
    });
}
</script>
{% endif %}
{% endblock content %}
