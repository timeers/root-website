{% load static %}{
  "name": "Root Database",
  "short_name": "RDB",
  "description": "The Root Database — a site for posting and discovering fan factions and other fan-created content for the woodland war game, Root, by Leder Games.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#5f788a",
