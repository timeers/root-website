    {
      "src": "{% static 'images/icon-512.png' %}",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "{% static 'images/icon-maskable-512.png' %}",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ]
}
